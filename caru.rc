# ============================================
# ЦЕНТР СЕРТИФИКАЦИИ (CA) - WorldSkills Almaty 2026
# ============================================
# РУССКАЯ ВЕРСИЯ (для понимания)
# ============================================
# Все действия выполняются на int-srv01

# --------------------------------------------
# 1. ПОДГОТОВКА
# --------------------------------------------

# Установка OpenSSL (обычно уже есть)
sudo apt update
sudo apt install -y openssl

# Создаем структуру папок для CA
mkdir -p ~/ca/{root,intermediate,newcerts,certs,crl,private}
или:
mkdir ~/ca
mkdir ~/ca/root
mkdir ~/ca/intermediate
mkdir ~/ca/newcerts
mkdir ~/ca/certs
mkdir ~/ca/crl
mkdir ~/ca/private

# переходим в CA
cd ~/ca

# Устанавливаем правильные права (только root может читать ключи)
chmod 700 private

# Создаем служебные файлы
echo '01' > serial
echo '01' > crlnumber
touch index.txt

# --------------------------------------------
# 2. КОРНЕВОЙ ЦЕНТР СЕРТИФИКАЦИИ (ROOT CA)
# --------------------------------------------
# Задание: Используйте "WS Root CA" в качестве имени (CN)

# Создаем конфигурационный файл для корневого CA
nano ~/ca/root-ca.conf

# Вставьте в файл:
[ ca ]
default_ca = CA_default

[ CA_default ]
database    = index.txt
serial      = serial
certs       = certs
new_certs_dir = newcerts
private_key = private/ca.key
certificate = ca.pem
default_md  = sha256
copy_extensions = copy

[ req ]
distinguished_name = req_distinguished_name
prompt = no
x509_extensions = v3_ca
default_md = sha256

[ req_distinguished_name ]
CN = WS Root CA
C = KZ
ST = Almaty
L = Almaty
O = WorldSkills
OU = CA Department

[ v3_ca ]
subjectKeyIdentifier = hash
authorityKeyIdentifier = keyid:always,issuer
basicConstraints = critical, CA:TRUE, pathlen:1
keyUsage = critical, keyCertSign, cRLSign


# Генерируем закрытый ключ корневого CA (4096 бит)
openssl genrsa -out private/ca.key 4096

# Создаем самоподписанный сертификат корневого CA (срок 10 лет)
openssl req -new -x509 -days 3650 -key private/ca.key -out ca.pem -config root-ca.conf

# --------------------------------------------
# 3. ПРОМЕЖУТОЧНЫЙ ЦЕНТР СЕРТИФИКАЦИИ
# --------------------------------------------
# Задание: Создайте один вспомогательный центр сертификации

# Создаем конфигурационный файл для промежуточного CA
nano ~/ca/intermediate-ca.conf

# Вставьте в файл:
[ req ]
distinguished_name = req_distinguished_name
prompt = no
x509_extensions = v3_ca
default_md = sha256

[ req_distinguished_name ]
CN = WS Intermediate CA
C = KZ
ST = Almaty
L = Almaty
O = WorldSkills
OU = Certificate Services

[ v3_ca ]
subjectKeyIdentifier = hash
authorityKeyIdentifier = keyid:always,issuer
basicConstraints = critical, CA:TRUE, pathlen:0
keyUsage = critical, keyCertSign, cRLSign

[ v3_server ]
subjectKeyIdentifier = hash
authorityKeyIdentifier = keyid,issuer
basicConstraints = critical, CA:FALSE
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth, clientAuth
subjectAltName = DNS:placeholder


# Генерируем ключ для промежуточного CA
openssl genrsa -out private/intermediate.key 4096

# Создаем запрос на сертификат (CSR) для промежуточного CA
openssl req -new -key private/intermediate.key -out intermediate.csr -config intermediate-ca.conf

# Подписываем промежуточный CA корневым CA
openssl ca -in intermediate.csr -out intermediate.pem -keyfile private/ca.key -cert ca.pem -config <(cat root-ca.conf) -days 1825 -extensions v3_ca

# Объединяем сертификаты для цепочки доверия
cat intermediate.pem ca.pem > services.pem

# --------------------------------------------
# 4. СЕРТИФИКАТ ДЛЯ ВЕБ-СЕРВЕРОВ
# --------------------------------------------
# Задание: для www.dmz.ws.kz

# Создаем конфигурационный файл для веб-сертификата
nano ~/ca/web-cert.conf

[ req ]
distinguished_name = req_distinguished_name
prompt = no
default_md = sha256

[ req_distinguished_name ]
CN = www.dmz.ws.kz
C = KZ
ST = Almaty
L = Almaty
O = WorldSkills
OU = Web Servers

[ v3_req ]
basicConstraints = CA:FALSE
keyUsage = digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth, clientAuth
subjectAltName = @alt_names

[ alt_names ]
DNS.1 = www.dmz.ws.kz
DNS.2 = dmz.ws.kz


# Генерируем ключ для веб-сервера
openssl genrsa -out private/web.key 2048

# Создаем запрос на сертификат
openssl req -new -key private/web.key -out web.csr -config web-cert.conf

# Подписываем веб-сертификат промежуточным CA. Ответь y на запросы подтверждения.
openssl ca -in web.csr -out web.pem -keyfile private/intermediate.key -cert intermediate.pem -config intermediate-ca.conf -extensions v3_req -days 365

# --------------------------------------------
# 5. СЕРТИФИКАТ ДЛЯ ПОЧТОВОГО СЕРВЕРА
# --------------------------------------------
# Задание: для mail.dmz.ws.kz

# Создаем конфигурационный файл для почтового сертификата
nano ~/ca/mail-cert.conf

[ req ]
distinguished_name = req_distinguished_name
prompt = no
default_md = sha256

[ req_distinguished_name ]
CN = mail.dmz.ws.kz
C = KZ
ST = Almaty
L = Almaty
O = WorldSkills
OU = Mail Servers

[ v3_req ]
basicConstraints = CA:FALSE
keyUsage = digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth, clientAuth
subjectAltName = @alt_names

[ alt_names ]
DNS.1 = mail.dmz.ws.kz
DNS.2 = dmz.ws.kz


# Генерируем ключ для почтового сервера
openssl genrsa -out private/mail.key 2048

# Создаем запрос на сертификат
openssl req -new -key private/mail.key -out mail.csr -config mail-cert.conf

# Подписываем почтовый сертификат промежуточным CA
openssl ca -in mail.csr -out mail.pem -keyfile private/intermediate.key -cert intermediate.pem -config intermediate-ca.conf -extensions v3_req -days 365

# Посмотреть сертификат
openssl x509 -in mail.pem -text -noout | grep -E "Subject:|DNS:"


# --------------------------------------------
# 6. СПИСКИ ОТЗЫВА (CRL) И ПОЛЯ AIA/CDP
# --------------------------------------------
# Задание: сертификаты должны содержать поля AIA и CDP

# Создаем конфигурацию для CA с поддержкой AIA и CDP
nano ~/ca/ca-with-crl.conf

[ ca ]
default_ca = CA_default

[ CA_default ]
database    = /home/user/ca/index.txt
serial      = /home/user/ca/serial
certs       = /home/user/ca/certs
new_certs_dir = /home/user/ca/newcerts
private_key = /home/user/ca/private/intermediate.key
certificate = /home/user/ca/intermediate.pem
default_md  = sha256
copy_extensions = copy
policy      = policy_loose
email_in_dn = optional
default_crl_days = 30

[ policy_loose ]
countryName             = optional
stateOrProvinceName     = optional
localityName            = optional
organizationName        = optional
organizationalUnitName  = optional
commonName              = supplied
emailAddress            = optional

[ req ]
distinguished_name = req_distinguished_name
prompt = no
x509_extensions = v3_ca
default_md = sha256

[ req_distinguished_name ]
CN = WS Intermediate CA
C = KZ
ST = Almaty
L = Almaty
O = WorldSkills
OU = Certificate Services

[ v3_ca ]
subjectKeyIdentifier = hash
authorityKeyIdentifier = keyid:always,issuer
basicConstraints = critical, CA:TRUE, pathlen:0
keyUsage = critical, keyCertSign, cRLSign
authorityInfoAccess = caIssuers;URI:http://ca.dmz.ws.kz/services.pem
crlDistributionPoints = URI:http://ca.dmz.ws.kz/crl.pem

[ v3_server ]
basicConstraints = CA:FALSE
keyUsage = digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth, clientAuth
authorityInfoAccess = caIssuers;URI:http://ca.dmz.ws.kz/services.pem
crlDistributionPoints = URI:http://ca.dmz.ws.kz/crl.pem
subjectAltName = DNS:placeholder

# Генерируем CRL (список отзыва)
openssl ca -gencrl -out crl/crl.pem -config ca-with-crl.conf

# Посмотреть созданный CRL
openssl crl -in crl/crl.pem -text -noout

# Переподписать веб-сертификат с CRL
openssl ca -in web.csr -out web-with-crl.pem -keyfile private/intermediate.key -cert intermediate.pem -config ca-with-crl.conf -extensions v3_server -days 365

# Переподписать почтовый сертификат с CRL
openssl ca -in mail.csr -out mail-with-crl.pem -keyfile private/intermediate.key -cert intermediate.pem -config ca-with-crl.conf -extensions v3_server -days 365

# Переименовать новые версии
cp web-with-crl.pem web.pem
cp mail-with-crl.pem mail.pem

# --------------------------------------------
# 7. ПУБЛИКАЦИЯ В /opt/grading/ca
# --------------------------------------------
# Задание: копия каждого сертификата в /opt/grading/ca

# Создаем целевую папку
sudo mkdir -p /opt/grading/ca

# Копируем все сертификаты
sudo cp ~/ca/ca.pem /opt/grading/ca/ca.pem
sudo cp ~/ca/services.pem /opt/grading/ca/services.pem
sudo cp ~/ca/web.pem /opt/grading/ca/web.pem
sudo cp ~/ca/mail.pem /opt/grading/ca/mail.pem
sudo cp ~/ca/private/ca.key /opt/grading/ca/ 2>/dev/null || echo "Ключи не копируем, только сертификаты"

# Проверяем результат
ls -la /opt/grading/ca/

# --------------------------------------------
# 8. ПРОВЕРКА СЕРТИФИКАТОВ
# --------------------------------------------

# Проверить корневой сертификат
openssl x509 -in /opt/grading/ca/ca.pem -text -noout | grep -E "Subject:|Issuer:|CA:"

# Проверить веб-сертификат
openssl x509 -in /opt/grading/ca/web.pem -text -noout | grep -E "Subject:|Issuer:|DNS:"

# Проверить цепочку доверия
openssl verify -CAfile /opt/grading/ca/ca.pem /opt/grading/ca/web.pem

# --------------------------------------------
# 9. ПОЛЕЗНЫЕ КОМАНДЫ ДЛЯ ОТЛАДКИ
# --------------------------------------------

# Посмотреть содержимое сертификата
openssl x509 -in сертификат.pem -text -noout

# Посмотреть закрытый ключ
openssl rsa -in private/файл.key -check

# Создать сертификат в формате PFX (для Windows)
# openssl pkcs12 -export -out cert.pfx -inkey private/web.key -in web.pem -certfile ca.pem

# --------------------------------------------
# 10. ЧАСТЫЕ ОШИБКИ И РЕШЕНИЯ
# --------------------------------------------

# ОШИБКА: unable to load private key
# Решение: проверь права доступа (chmod 600 private)

# ОШИБКА: signature algorithm mismatch
# Решение: проверь параметр default_md в конфигах (должен быть sha256)

# ОШИБКА: certificate verification failed
# Решение: проверь цепочку - промежуточный должен быть подписан корневым

# --------------------------------------------
# 11. ШПАРГАЛКА ПО ОСНОВНЫМ ПОНЯТИЯМ
# --------------------------------------------

: '
# CA (Certificate Authority) - центр сертификации
#   Root CA - корневой (сам себя подписывает)
#   Intermediate CA - промежуточный (подписан корневым)

# PEM - формат сертификатов (текстовый, начинается с -----BEGIN CERTIFICATE-----)
# KEY - закрытый ключ (-----BEGIN PRIVATE KEY-----)
# CSR - запрос на сертификат (-----BEGIN CERTIFICATE REQUEST-----)

# Поля в сертификате:
#   CN (Common Name) - основное имя (www.dmz.ws.kz)
#   SAN (Subject Alternative Name) - дополнительные имена
#   AIA (Authority Info Access) - где скачать сертификат CA
#   CDP (CRL Distribution Points) - где скачать список отзыва

# Сроки:
#   Root CA - 10 лет (3650 дней)
#   Intermediate - 5 лет (1825 дней)
#   Серверные - 1 год (365 дней)
