sudo nft list ruleset | grep counter

# Add temporary logging rule
sudo nft add rule ip filter forward log prefix "DEBUG-FW: " accept

# Delete rule (need handle)
sudo nft -a list ruleset
sudo nft delete rule ip filter forward handle 123

# Restart nftables
sudo systemctl restart nftables

