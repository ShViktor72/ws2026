smbclient //10.1.10.10/public -N -c "ls"
smbclient //10.1.10.10/internal -U jamie -c "ls"

# 6. Check services autostart
sudo systemctl is-enabled nftables
sudo systemctl is-enabled wg-quick@wg0
sudo systemctl is-enabled squid

