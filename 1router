# --------------------------------------------
# 2. DNS SERVER (BIND9) ON int-srv01
# --------------------------------------------
# Task: Create int.ws.kz zone, reverse zones, SRV record for LDAP

# Install BIND9
sudo apt update
sudo apt install -y bind9 bind9utils

# Check service status
sudo systemctl status bind9

# --------------------------------------------
# 2.1 Configure zones
# --------------------------------------------
sudo nano /etc/bind/named.conf.local

# Add these lines:
zone "int.ws.kz" {
    type master;
    file "/etc/bind/db.int.ws.kz";
};

zone "10.1.10.in-addr.arpa" {
    type master;
    file "/etc/bind/db.10.1.10";
};

# --------------------------------------------
# 2.2 Create forward zone file
# --------------------------------------------
sudo nano /etc/bind/db.int.ws.kz

$TTL    604800
@       IN      SOA     int-srv01.int.ws.kz. admin.int.ws.kz. (
                              2026030501   ; Serial (YYYYMMDDNN)
                              604800       ; Refresh
                              86400        ; Retry
                              2419200      ; Expire
                              604800 )     ; Negative Cache TTL

; Name servers
@       IN      NS      int-srv01.int.ws.kz.

; A records (IPv4)
int-srv01       IN      A       10.1.10.10
fw              IN      A       10.1.10.1

; SRV record for LDAP (REQUIRED by task)
_ldap._tcp      IN      SRV     10 50 389 auth.int.ws.kz.
auth            IN      CNAME   int-srv01.int.ws.kz.

# --------------------------------------------
# 2.3 Create reverse zone file
# --------------------------------------------
sudo nano /etc/bind/db.10.1.10

$TTL    604800
@       IN      SOA     int-srv01.int.ws.kz. admin.int.ws.kz. (
                              2026030501   ; Serial
                              604800       ; Refresh
                              86400        ; Retry
                              2419200      ; Expire
                              604800 )     ; Negative Cache TTL

; Name servers
@       IN      NS      int-srv01.int.ws.kz.

; PTR records (reverse)
10      IN      PTR     int-srv01.int.ws.kz.
1       IN      PTR     fw.int.ws.kz.

# --------------------------------------------
# 2.4 Enable recursion (for clients)
# --------------------------------------------
sudo nano /etc/bind/named.conf.options

options {
    directory "/var/cache/bind";
    
    # Enable recursion for internal networks
    recursion yes;
    allow-query { any; };
    allow-recursion { 127.0.0.1; 10.1.10.0/24; 10.1.20.0/24; };
    allow-query-cache { 127.0.0.1; 10.1.10.0/24; 10.1.20.0/24; };
    
    # Listen on all interfaces
    listen-on { any; };
    listen-on-v6 { any; };
    
    # Forwarders (optional, for external resolution)
    forwarders {
        8.8.8.8;
        8.8.4.4;
    };
};

