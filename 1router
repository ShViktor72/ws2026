🔥 Правильные правила nftables для этой схемы
bash
# Таблица NAT (только для проброса портов с enp0s9, как в задании)
table ip nat {
    chain prerouting {
        type nat hook prerouting priority -100; policy accept;
        iif enp0s9 tcp dport 80 dnat to 10.1.20.20
        iif enp0s9 tcp dport 443 dnat to 10.1.20.20
        iif enp0s9 udp dport 53 dnat to 10.1.20.21
        iif enp0s9 udp dport 53 dnat to 10.1.20.22
        iif enp0s9 tcp dport 53 dnat to 10.1.20.21
        iif enp0s9 tcp dport 53 dnat to 10.1.20.22
    }
    # MASQUERADE НЕ НУЖЕН — его делает gateway
}

# Таблица фильтрации (разрешить маршрутизацию)
table ip filter {
    chain forward {
        type filter hook forward priority 0; policy drop;

        ct state { established, related } accept

        # Разрешить INT -> DMZ
        iif enp0s3 oif enp0s8 accept
        # Разрешить DMZ -> INT
        iif enp0s8 oif enp0s3 accept

        # Разрешить INT -> WAN (интернет через gateway)
        iif enp0s3 oif enp0s10 accept
        # Разрешить DMZ -> WAN (интернет через gateway)
        iif enp0s8 oif enp0s10 accept

        # Разрешить ответы из интернета обратно
        iif enp0s10 oif { enp0s3, enp0s8 } ct state established,related accept

        # Разрешить почтовику доступ к LDAP
        iif enp0s8 ip saddr 10.1.20.10 oif enp0s3 ip daddr 10.1.10.10 tcp dport 389 accept

        log prefix "FW-FORWARD-DROP: " drop
    }
}
