# ============================================
# NETWORK CONFIGURATION
# ============================================
# Usage: source .network.rc or open in nano
# All commands need root (sudo)

# --------------------------------------------
# 1. BASIC DIAGNOSTIC COMMANDS
# --------------------------------------------

# Show all interfaces and IPs
ip a

# Show only IP addresses (brief)
ip -4 a | grep inet
ip -6 a | grep inet6

# Show routing table (default gateway)
ip route
ip -6 route

# Test connectivity
ping -c 4 8.8.8.8
ping6 -c 4 2001:4860:4860::8888

# Check DNS
cat /etc/resolv.conf
nslookup google.com
dig google.com

# Check hostname
hostname
hostnamectl

# --------------------------------------------
# 2. INTERFACE CONFIGURATION (EDITING)
# --------------------------------------------

# Network config file
sudo nano /etc/network/interfaces

# After changes - restart network
sudo systemctl restart networking
# OR
sudo /etc/init.d/networking restart

# --------------------------------------------
# 3. CONFIGURATION TEMPLATES FOR EACH VM
# --------------------------------------------

# ===== fw.ws.kz (firewall, 3 interfaces) =====

auto lo
iface lo inet loopback

# INT 
auto enp0s3
iface enp0s3 inet static
    address 10.1.10.1
    netmask 255.255.255.0
iface enp0s3 inet6 static
    address 2001:db8:1001:10::1/64

# DMZ 
auto enp0s8
iface enp0s8 inet static
    address 10.1.20.1
    netmask 255.255.255.0
iface enp0s8 inet6 static
    address 2001:db8:1001:20::1/64

# WAN 
auto enp0s9
iface enp0s9 inet static
    address 1.1.1.10
    netmask 255.255.255.0
    gateway 1.1.1.1
iface enp0s9 inet6 static
    address 2001:db8:1111::10/64


# --------------------------------------------
# 5. COMMON PROBLEMS & SOLUTIONS
# --------------------------------------------

# Problem: no internet after configuration
# Solution: check default route
ip route | grep default
# If missing - add:
sudo ip route add default via 1.1.1.1 dev enp0s9

# Problem: interface exists but not working
# Solution: bring up manually
sudo ifup enp0s3
# OR
sudo ip link set enp0s3 up

# Problem: wrong interface names (enp0s3 vs eth0)
# Solution: check real names
ip a
# update /etc/network/interfaces with correct names

# Problem: can't ping IPv6
# Solution: check IPv6 forwarding
sysctl net.ipv6.conf.all.forwarding
# Enable if needed:
sudo sysctl -w net.ipv6.conf.all.forwarding=1

# Problem: DNS not working
# Solution: check /etc/resolv.conf
echo "nameserver 8.8.8.8" | sudo tee /etc/resolv.conf
echo "nameserver 2001:4860:4860::8888" | sudo tee -a /etc/resolv.conf

