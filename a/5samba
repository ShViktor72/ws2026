4.3 Create Shared Directories
-------------------------------------------------------------------------

# Create directories
sudo mkdir -p /srv/samba/public
sudo mkdir -p /srv/samba/internal

# Set permissions for public (everyone can read, authenticated write)
sudo chmod 1777 /srv/samba/public  

# Set permissions for internal (only jamie)
sudo chown jamie:jamie /srv/samba/internal
sudo chmod 770 /srv/samba/internal

