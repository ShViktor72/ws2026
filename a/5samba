4.1 Install Samba
-------------------------------------------------------------------------
ip route | grep default
default via 10.1.10.1 dev enp0s3 onlink
default via 192.168.0.1 dev enp0s10 proto dhcp src 192.168.0.211 metric 1003

# Remove the default route via 10.1.10.1 (temporary)
sudo ip route del default via 10.1.10.1 dev enp0s3


# Update package list (using bridge interface if needed)
sudo apt update

# Install Samba
sudo apt install -y samba samba-common-bin

# Install smbclient for testing
sudo apt install -y smbclient

# Recovery the default route via 10.1.10.1
sudo ip route add default via 10.1.10.1 dev enp0s3

# Check version and status
sudo systemctl status smbd
