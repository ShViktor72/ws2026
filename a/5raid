# View available drives
lsblk

# Install mdadm
sudo apt install -y mdadm

# Create RAID1 (replace sdb and sdc with your drives)
sudo mdadm --create /dev/md0 --level=1 --raid-devices=2 /dev/sdb /dev/sdc

# Check status
cat /proc/mdstat
sudo mdadm --detail /dev/md0

# Create a file system
sudo mkfs.ext4 /dev/md0

# Create a mount point
sudo mkdir -p /opt/backup

# Get the UUID
sudo blkid /dev/md0

# Add to fstab (replace the UUID with the obtained one)
echo "UUID=YOUR_UUID  /opt/backup   ext4   defaults   0   2" | sudo tee -a /etc/fstab

# Mount
sudo mount -a

# Check
df -h /opt/backup

# Save RAID configuration
sudo mdadm --detail --scan | sudo tee -a /etc/mdadm/mdadm.conf
sudo update-initramfs -u

# Check after reboot:
sudo reboot
# after reboot:
lsblk
df -h /opt/backup
cat /proc/mdstat