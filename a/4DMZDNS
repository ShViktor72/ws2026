sudo nano /etc/bind/named.conf.local

// DMZ forward zone
zone "dmz.ws.kz" {
    type master;
    file "/etc/bind/db.dmz.ws.kz";
	allow-transfer { 10.1.10.10; 10.1.20.22; }; 
};

// Reverse zone for 10.1.20.0/24
zone "20.1.10.in-addr.arpa" {
    type master;
    file "/etc/bind/db.10.1.20";
	allow-transfer { 10.1.10.10; 10.1.20.22; };
};

// IPv6 reverse zone for 2001:db8:1001:20::/64
zone "0.2.0.0.1.0.0.1.8.b.d.0.1.0.0.2.ip6.arpa" {
    type master;
    file "/etc/bind/db.2001.db8.1001.20";
	allow-transfer { 10.1.10.10; 10.1.20.22; };
};

