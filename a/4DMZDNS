# Create DMZ zone file
sudo nano /etc/bind/db.dmz.ws.kz

; BIND data file for dmz.ws.kz
$TTL    604800
@       IN      SOA     ha-prx01.dmz.ws.kz. admin.dmz.ws.kz. (
                  2026030601      ; Serial
                  604800          ; Refresh
                  86400           ; Retry
                  2419200         ; Expire
                  604800 )        ; Negative Cache TTL

; Name servers
@       IN      NS      ha-prx01.dmz.ws.kz.

; Host records (from Table 1)
mail            IN      A       10.1.20.10
mail            IN      AAAA    2001:db8:1001:20::10

ha-prx01        IN      A       10.1.20.21
ha-prx01        IN      AAAA    2001:db8:1001:20::21

ha-prx02        IN      A       10.1.20.22
ha-prx02        IN      AAAA    2001:db8:1001:20::22

web01           IN      A       10.1.20.31
web01           IN      AAAA    2001:db8:1001:20::31

web02           IN      A       10.1.20.32
web02           IN      AAAA    2001:db8:1001:20::32

fw              IN      A       10.1.20.1
fw              IN      AAAA    2001:db8:1001:20::1

; Virtual IP (not a host, but we need DNS for it)
prx-vrrp        IN      A       10.1.20.20
prx-vrrp        IN      AAAA    2001:db8:1001:20::20

; CNAME for www (MANDATORY: must be CNAME, not A record)
www         IN  CNAME   prx-vrrp.dmz.ws.kz.


