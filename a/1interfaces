-------------------------------------------------------------------------
1.3 Network Interface Naming Convention
-------------------------------------------------------------------------
# fw.ws.kz
# open:
sudo nano /etc/network/interfaces

# insert:
# Loopback interface
auto lo
iface lo inet loopback

# WAN 
auto enp0s3 
iface enp0s3 inet static
address 1.1.1.10/24

iface enp0s3 inet6 static
address 2001:db8:1111::10/64

# INT 
auto enp0s8 
iface enp0s8 inet static
address 10.1.10.1/24

iface enp0s8 inet6 static
address 2001:db8:1001:10::1/64

# DMZ 
auto enp0s9 
iface enp0s9 inet static
address 10.1.20.1/24

iface enp0s9 inet6 static
address 2001:db8:1001:20::1/64

# internet Bridge interface 
# Will be disabled during competition
auto enp0s10 
iface enp0s10 inet dhcp

# restart 
sudo systemctl restart networking

# check:
ip a

# Internal Server (int-srv01.int.ws.kz) 
# open:
sudo nano /etc/network/interfaces

# insert:
# INT 
auto enp0s3 
iface enp0s3 inet static
address 10.1.10.10/24
gateway 10.1.10.1

iface enp0s3 inet6 static
address 2001:db8:1001:10::10/64
gateway 2001:db8:1001:10::1

# restart 
sudo systemctl restart networking

# check:
ip a

