# Example: For firewall server (fw.ws.kz)
sudo hostnamectl set-hostname fw.ws.kz

# Verify hostname
hostname

# Update /etc/hosts to prevent local resolution issues
sudo nano /etc/hosts

127.0.0.1 localhost
127.0.1.1   fw.ws.kz fw
::1 localhost ip6-localhost ip6-loopback
ff02::1 ip6-allnodes
ff02::2 ip6-allrouters

