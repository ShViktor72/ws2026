# --------------------------------------------
# 1. PREREQUISITES
# --------------------------------------------
# Task: Ensure IP forwarding is enabled and interfaces are correct

# Check interface configuration
ip a
# INT: enp0s3 (10.1.10.1/24 + IPv6)
# DMZ: enp0s8 (10.1.20.1/24 + IPv6)
# WAN: enp0s9 (1.1.1.10/24 + IPv6) with gateway 1.1.1.1

# Check default route (must point to 1.1.1.1)
ip route show default

# Enable IP forwarding (if not already done)
sudo sysctl -w net.ipv4.ip_forward=1
sudo sysctl -w net.ipv6.conf.all.forwarding=1

# Make permanent
echo "net.ipv4.ip_forward=1" | sudo tee -a /etc/sysctl.conf
echo "net.ipv6.conf.all.forwarding=1" | sudo tee -a /etc/sysctl.conf

# --------------------------------------------
# 2. INSTALL AND PREPARE NFTABLES
# --------------------------------------------
# nftables is the standard firewall framework in Debian

# Install (usually already present)
sudo apt update
sudo apt install -y nftables

# Enable and start
sudo systemctl enable nftables
sudo systemctl start nftables

# Clear any existing rules
sudo nft flush ruleset

