--------------------------------------------
ROUTING AND FIREWALL CONFIGURATION (fw.ws.kz)
--------------------------------------------
-------------------------------------------------------------------------
Enable Packet Forwarding
-------------------------------------------------------------------------
# Edit sysctl.d/99-forwarding.conf to enable IPv4 and IPv6 forwarding (permanent)
sudo nano /etc/sysctl.d/99-router.conf

# insert:
net.ipv4.ip_forward = 1
net.ipv6.conf.all.forwarding = 1

# Save and exit (Ctrl+O, Ctrl+X in nano)
# Apply immediately
sudo sysctl --system

# Verify
sudo sysctl net.ipv4.ip_forward
sudo sysctl net.ipv6.conf.all.forwarding

