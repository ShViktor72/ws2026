--------------------------------------------
2. ROUTING AND FIREWALL CONFIGURATION (fw.ws.kz)
--------------------------------------------
# Configure fw.ws.kz as router with nftables
#  Initial policy: everything allowed (for testing)
#Will be refined later according to competition requirements
-------------------------------------------------------------------------
2.1 Enable Packet Forwarding
-------------------------------------------------------------------------
# Edit sysctl.conf to enable IPv4 and IPv6 forwarding (permanent)
sudo nano /etc/sysctl.conf

# Add or uncomment these lines:
net.ipv4.ip_forward = 1
net.ipv6.conf.all.forwarding = 1

# Edit sysctl.d/99-forwarding.conf to enable IPv4 and IPv6 forwarding (permanent)
sudo nano /etc/sysctl.d/99-forwarding.conf

# insert:
net.ipv4.ip_forward = 1
net.ipv6.conf.all.forwarding = 1

# Save and exit (Ctrl+O, Ctrl+X in nano)
# Apply immediately
sudo sysctl -p

# Verify
sudo sysctl net.ipv4.ip_forward
sudo sysctl net.ipv6.conf.all.forwarding

-------------------------------------------------------------------------
2.2 Install and Initialize nftables
-------------------------------------------------------------------------
# Enable and start nftables service
sudo systemctl enable nftables
sudo systemctl start nftables


# Flush any existing rules
sudo nft flush ruleset

-------------------------------------------------------------------------
2.3 Basic nftables Configuration (EVERYTHING ALLOWED)
-------------------------------------------------------------------------
# Open
sudo nano /etc/nftables.conf

# insert:

#!/usr/sbin/nft -f

flush ruleset

table inet filter {
    chain input {
        type filter hook input priority 0; policy accept;
    }
    
    chain forward {
        type filter hook forward priority 0; policy accept;
    }
    
    chain output {
        type filter hook output priority 0; policy accept;
    }
}


# Load the configuration
sudo nft -f /etc/nftables.conf

-------------------------------------------------------------------------
2.5 Save nftables Configuration and Enable at Boot
-------------------------------------------------------------------------
# Save current ruleset (if not already saved)
sudo nft list ruleset | sudo tee /etc/nftables.conf

# Ensure nftables loads rules at boot
sudo systemctl enable nftables
sudo systemctl start nftables
sudo systemctl status nftables
