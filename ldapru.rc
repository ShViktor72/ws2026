# ============================================
# LDAP НАСТРОЙКА 
# ============================================

# --------------------------------------------
# 1. УСТАНОВКА
# --------------------------------------------

# Установка сервера и утилит
sudo apt update
sudo apt install -y slapd ldap-utils

# После установки проверить статус
sudo systemctl status slapd

# --------------------------------------------
# 2. ПЕРВОНАЧАЛЬНАЯ НАСТРОЙКА (если ошиблись при установке)
# --------------------------------------------

# Переконфигурировать slapd (запускает мастер)
sudo dpkg-reconfigure slapd

# ОТВЕТЫ НА ВОПРОСЫ МАСТЕРА:
# ┌─────────────────────────────────────┐
# │ Пропустить настройку OpenLDAP?      │ → Нет
# │ DNS domain name?                    │ → int.ws.kz
# │ Organization name?                   │ → WS
# │ Administrator password?              │ → Skill39!
# │ Confirm password?                    │ → Skill39!
# │ Database backend?                    │ → MDB
# │ Remove database when purge?          │ → Нет
# │ Move old database?                   │ → Да
# │ Allow LDAPv2 protocol?                │ → Нет
# └─────────────────────────────────────┘

# --------------------------------------------
# 3. ПРОВЕРКА ТЕКУЩЕЙ КОНФИГУРАЦИИ
# --------------------------------------------

# Посмотреть, какой домен установлен
sudo ldapsearch -x -LLL -b "" -s base namingContexts
# Должен показать: dc=int,dc=ws,dc=kz

# Посмотреть все записи в базе
sudo slapcat

# Посмотреть только структуру (dn)
sudo slapcat | grep ^dn:

# --------------------------------------------
# 4. СОЗДАНИЕ СТРУКТУРЫ (OU - Organizational Units)
# --------------------------------------------

# Создаем файл с описанием структуры
cat > /tmp/base.ldif << 'EOF'
# People - корневая папка для всех пользователей
dn: ou=People,dc=int,dc=ws,dc=kz
objectClass: organizationalUnit
ou: People

# Group - для групп (понадобится позже)
dn: ou=Group,dc=int,dc=ws,dc=kz
objectClass: organizationalUnit
ou: Group

# Employees - сотрудники (внутри People)
dn: ou=Employees,ou=People,dc=int,dc=ws,dc=kz
objectClass: organizationalUnit
ou: Employees
EOF

# Добавляем структуру в LDAP
ldapadd -x -D cn=admin,dc=int,dc=ws,dc=kz -W -f /tmp/base.ldif
# Пароль: Skill39!

# Проверяем, что добавилось
ldapsearch -x -b "dc=int,dc=ws,dc=kz" ou

# --------------------------------------------
# 5. ДОБАВЛЕНИЕ ПОЛЬЗОВАТЕЛЕЙ (Таблица 2 из задания)
# --------------------------------------------

# Создаем файл с пользователями
nano /tmp/users.ldif
# Jamie Oliver
dn: uid=jamie,ou=Employees,ou=People,dc=int,dc=ws,dc=kz
objectClass: inetOrgPerson
objectClass: posixAccount
objectClass: shadowAccount
uid: jamie
cn: Jamie Oliver
sn: Oliver
givenName: Jamie
displayName: Jamie Oliver
mail: jamie.oliver@dmz.ws.kz
# userPassword: {CRYPT}Skill39!
uidNumber: 10001
gidNumber: 5000
homeDirectory: /home/jamie
loginShell: /bin/bash

# Peter Fox
dn: uid=peter,ou=Employees,ou=People,dc=int,dc=ws,dc=kz
objectClass: inetOrgPerson
objectClass: posixAccount
objectClass: shadowAccount
uid: peter
cn: Peter Fox
sn: Fox
givenName: Peter
displayName: Peter Fox
mail: peter.fox@dmz.ws.kz
# userPassword: {CRYPT}Skill39!
uidNumber: 10002
gidNumber: 5000
homeDirectory: /home/peter
loginShell: /bin/bash

# Administrator (в корне, не в Employees)
dn: uid=admin,dc=int,dc=ws,dc=kz
objectClass: inetOrgPerson
objectClass: posixAccount
objectClass: shadowAccount
uid: admin
cn: Administrator
sn: Administrator
givenName: Admin
displayName: Administrator
# userPassword: {CRYPT}Skill39!
uidNumber: 10000
gidNumber: 5000
homeDirectory: /home/admin
loginShell: /bin/bash


# Добавляем пользователей
ldapadd -x -D cn=admin,dc=int,dc=ws,dc=kz -W -f /tmp/users.ldif

# Установить пароль для jamie Password: Skill39!
ldappasswd -x -D cn=admin,dc=int,dc=ws,dc=kz -W -S uid=jamie,ou=Employees,ou=People,dc=int,dc=ws,dc=kz
# Система спросит:
# New password: — введи Skill39!
# Re-enter new password: — повтори Skill39!
# Повтори для peter и admin.

# --------------------------------------------
# 6. ПРОВЕРКА ДОБАВЛЕННЫХ ПОЛЬЗОВАТЕЛЕЙ
# --------------------------------------------

# Найти конкретного пользователя
ldapsearch -x -b "dc=int,dc=ws,dc=kz" uid=jamie

# Найти всех пользователей
ldapsearch -x -b "dc=int,dc=ws,dc=kz" "(objectClass=inetOrgPerson)"

# Проверить аутентификацию пользователя
ldapwhoami -x -H ldap://localhost -D uid=jamie,ou=Employees,ou=People,dc=int,dc=ws,dc=kz -W
# (должен запросить пароль Skill39! и показать dn пользователя)

# --------------------------------------------
# 7. ЕСЛИ ОШИБСЯ - УДАЛЕНИЕ И ИСПРАВЛЕНИЕ
# --------------------------------------------

# Удалить пользователя
# ldapdelete -x -D cn=admin,dc=int,dc=ws,dc=kz -W "uid=jamie,ou=Employees,ou=People,dc=int,dc=ws,dc=kz"

# Удалить всю структуру (осторожно!)
# ldapdelete -x -D cn=admin,dc=int,dc=ws,dc=kz -W -r "dc=int,dc=ws,dc=kz"

# Изменить пароль пользователя
# ldappasswd -x -D cn=admin,dc=int,dc=ws,dc=kz -W -S uid=jamie,ou=Employees,ou=People,dc=int,dc=ws,dc=kz

# --------------------------------------------
# 9. ПОЛЕЗНЫЕ КОМАНДЫ ДЛЯ ОТЛАДКИ
# --------------------------------------------

# Посмотреть логи LDAP
sudo tail -f /var/log/syslog | grep slapd

# Проверить, слушает ли slapd порты
sudo netstat -tulpn | grep slapd
# Должен быть 389 (LDAP) и maybe 636 (LDAPS)

# Перезапустить сервер
sudo systemctl restart slapd

# Остановить/запустить
sudo systemctl stop slapd
sudo systemctl start slapd

# --------------------------------------------
# 10. ЧАСТЫЕ ОШИБКИ И РЕШЕНИЯ
# --------------------------------------------

# ОШИБКА: ldap_bind: Invalid credentials (49)
# Решение: неправильный пароль администратора

# ОШИБКА: ldap_add: No such object (32)
# Решение: не существует родительской OU, создай сначала структуру

# ОШИБКА: ldap_add: Already exists (68)
# Решение: такая запись уже есть, используй modify вместо add

# --------------------------------------------
# 11. ШПАРГАЛКА ПО ФОРМАТУ LDIF
# --------------------------------------------

# DN (Distinguished Name) - уникальный путь к объекту
dn: uid=jamie,ou=Employees,ou=People,dc=int,dc=ws,dc=kz

# objectClass - определяет, какие атрибуты можно использовать
objectClass: inetOrgPerson    # для людей (имя, фамилия, email)
objectClass: posixAccount     # для Linux-пользователей (uid, gid, home)

# Атрибуты:
uid: jamie                    # логин
cn: Jamie Oliver              # полное имя (common name)
sn: Oliver                    # фамилия (surname)
givenName: Jamie              # имя
mail: jamie.oliver@dmz.ws.kz  # email
userPassword: {CRYPT}Skill39! # пароль
uidNumber: 10001              # UNIX uid
gidNumber: 5000               # UNIX gid
homeDirectory: /home/jamie    # домашняя папка
loginShell: /bin/bash         # шелл
